---
layout: null
permalink: /postmortem/postmortems.json
---
[
{% for post in site.posts %}{
  "title": {{ post.title | jsonify }},
  "subtitle": {{ post.subtitle | default: "" | jsonify }},
  "description": {{ post.description | default: post.excerpt | strip_html | strip_newlines | jsonify }},
  "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
  "tags": {{ post.tags | jsonify }},
  "cover": {{ post.cover | default: "" | jsonify }},
  "url": {{ post.url | relative_url | jsonify }},
  "reading_time": {{ post.content | strip_html | number_of_words | divided_by: 200 | at_least: 1 }}
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
