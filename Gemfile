source "https://rubygems.org"

# GitHub Pages builds this site remotely with its own pinned Jekyll version
# via the `github-pages` gem's supported plugin set (jekyll-feed,
# jekyll-seo-tag, jekyll-sitemap — all used below and all on GitHub's safe
# list). Locally we use a modern, actively maintained Jekyll instead of the
# `github-pages` gem itself, because that gem force-pins Jekyll 3.9 (2018),
# which is incompatible with current Ruby. Only standard Jekyll/Liquid
# features and GitHub-Pages-safelisted plugins are used in this repo, so
# output matches what GitHub Pages builds.
gem "jekyll", "~> 4.3"
gem "jekyll-feed"
gem "jekyll-seo-tag"
gem "jekyll-sitemap"
gem "webrick"
